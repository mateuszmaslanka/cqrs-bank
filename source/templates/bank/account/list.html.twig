{% extends 'base.html.twig' %}

{% block body %}
    <h1>Bank accounts</h1>
    <ol>
        {% for bankAccount in bankAccounts %}
            <li>
                <a href="{{ path('cqrs_bank_account_details', {id: bankAccount.id}) }}">{{ bankAccount.accountNumber.format }}</a>
                ~~~~~ {{ bankAccount.accountBalance }} ~~~~~ Deposit: 
                <a href="{{ path('cqrs_bank_account_deposit', {accountNumber: bankAccount.accountNumber, amount: 10000}) }}">+100 EUR</a>
            </li>
        {% endfor %}
    </ol>
{% endblock %}
